{
  "manifest_version": 3,
  "name": "Vendor Image Grabber",
  "version": "2.0.0",
  "description": "Bulk-download product images from furniture vendor websites. Supports multiple vendors with custom scrapers.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "vendors/*"],
      "matches": ["<all_urls>"]
    }
  ]
}

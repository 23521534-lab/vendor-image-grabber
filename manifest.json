{
  "manifest_version": 3,
  "name": "Vendor Image Grabber",
  "version": "2.0.0",
  "description": "Bulk-download product images from furniture vendor websites. Supports multiple vendors with custom scrapers.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendors/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
